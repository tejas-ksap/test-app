          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="M7" value="7. SELECT where availability &gt; 0" style="html=1;verticalAlign=bottom;endArrow=block;" edge="1" parent="1" source="L_property_act" target="L_db_act">
