        <mxCell id="M10" value="10. validate &amp; forward" style="html=1;verticalAlign=bottom;endArrow=block;entryX=0;entryY=0;" edge="1" parent="1" source="L_gateway_act" target="L_booking_act">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- FRAGMENT: ALT - Vacancy Check -->
        <mxCell id="F_alt_vacancy" value="alt [Vacancy Available]" style="shape=umlFrame;whiteSpace=wrap;html=1;width=120;height=30;boundedLbl=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="700" width="1400" height="500" as="geometry" />
        </mxCell>

        <mxCell id="M11" value="11. findById(pgId)" style="html=1;verticalAlign=bottom;endArrow=block;" edge="1" parent="1" source="L_booking_act" target="L_db_act">
