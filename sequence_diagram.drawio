        </mxCell>
        <mxCell id="M8" value="8. List&lt;PgProperty&gt;" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;exitX=0;exitY=1;" edge="1" parent="1" source="L_property_act" target="L_tenant_act">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Step 3: Booking (Critical Path) -->
        <mxCell id="M9" value="9. createBooking(Booking)" style="html=1;verticalAlign=bottom;endArrow=block;" edge="1" parent="1" source="L_tenant_act" target="L_gateway_act">
